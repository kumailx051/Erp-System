# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Redis Configuration (Optional - for session/cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Sequelize Options
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
